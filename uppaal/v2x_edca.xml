<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC "-//Uppaal Team//DTD Flat System 1.1//EN" "http://www.it.uu.se/research/group/darts/uppaal/flat-1_2.dtd">
<nta>
  <declaration>// ============================================================
// Parameters (aligned with veins_qos/simulations/veins_inet_light/omnetpp.ini)
// ============================================================
const int blockDuration = 120;
const int maxContinuousBlock = 0;   // 0 means uncapped, matching current edca_v2x config
const int sendingGuardTimeout = 50;
const int voQueueThreshold = 1;

const int crashStart = 30000;
const int crashDuration = 30000;
const int sendInterval = 100;
const int repeatCount = 3;
const int repeatGapMin = 15;   // repeatGap - repeatJitter
const int repeatGapMax = 25;   // repeatGap + repeatJitter
const int voTxDuration = 8;
const int beRequestInterval = 25;
const int mediumFreeDuration = 40;
const int mediumBusyDuration = 15;
const int voDedupWindow = 200;

// ============================================================
// Synchronization channels
// ============================================================
broadcast chan vo_demand;
broadcast chan be_request;
broadcast chan grant_be;
broadcast chan grant_vo;
broadcast chan vo_tx_done_pending;
broadcast chan vo_tx_done_clear;

// ============================================================
// Shared observables/counters
// ============================================================
clock g;
bool medium_free = true;
bool burstDone = false;
int voQueueDepth = 0;
int beGrantCount = 0;
int voGrantCount = 0;
int logicalVoRx = 0;
int duplicateVoRx = 0;

// helper used in assignments where we need bounded decrement
int dec1(int x) {
  if (x &gt; 0) return x - 1;
  return 0;
}</declaration>

  <template>
    <name x="5" y="5">Medium</name>
    <declaration>clock m;</declaration>
    <location id="medium_free_loc" x="0" y="0">
      <name x="-18" y="-34">FREE</name>
      <label kind="invariant" x="-46" y="20">m &lt;= mediumFreeDuration</label>
    </location>
    <location id="medium_busy_loc" x="220" y="0">
      <name x="196" y="-34">BUSY</name>
      <label kind="invariant" x="170" y="20">m &lt;= mediumBusyDuration</label>
    </location>
    <init ref="medium_free_loc"/>
    <transition>
      <source ref="medium_free_loc"/>
      <target ref="medium_busy_loc"/>
      <label kind="guard" x="28" y="-52">m &gt;= mediumFreeDuration</label>
      <label kind="assignment" x="20" y="-24">m = 0, medium_free = false</label>
    </transition>
    <transition>
      <source ref="medium_busy_loc"/>
      <target ref="medium_free_loc"/>
      <label kind="guard" x="18" y="48">m &gt;= mediumBusyDuration</label>
      <label kind="assignment" x="12" y="76">m = 0, medium_free = true</label>
    </transition>
  </template>

  <template>
    <name x="5" y="5">BeTraffic</name>
    <declaration>clock b;</declaration>
    <location id="be_active" x="0" y="0">
      <name x="-22" y="-34">ACTIVE</name>
      <label kind="invariant" x="-52" y="20">b &lt;= beRequestInterval</label>
    </location>
    <init ref="be_active"/>
    <transition>
      <source ref="be_active"/>
      <target ref="be_active"/>
      <label kind="guard" x="22" y="-52">b &gt;= beRequestInterval</label>
      <label kind="synchronisation" x="26" y="-24">be_request!</label>
      <label kind="assignment" x="30" y="4">b = 0</label>
    </transition>
  </template>

  <template>
    <name x="5" y="5">CrashWorkload</name>
    <declaration>clock gap;
clock waitBurst;
int rep = 0;</declaration>
    <location id="crash_warmup" x="0" y="0">
      <name x="-26" y="-34">WARMUP</name>
      <label kind="invariant" x="-52" y="20">g &lt;= crashStart</label>
    </location>
    <location id="crash_emit" x="240" y="0">
      <name x="212" y="-34">EMIT</name>
    </location>
    <location id="crash_repeat_wait" x="470" y="0">
      <name x="422" y="-34">REPEAT_WAIT</name>
      <label kind="invariant" x="392" y="20">gap &lt;= repeatGapMax</label>
    </location>
    <location id="crash_between" x="240" y="180">
      <name x="194" y="210">WAIT_NEXT_BURST</name>
      <label kind="invariant" x="172" y="238">waitBurst &lt;= sendInterval</label>
    </location>
    <location id="crash_done" x="470" y="180">
      <name x="448" y="210">DONE</name>
    </location>
    <init ref="crash_warmup"/>
    <transition>
      <source ref="crash_warmup"/>
      <target ref="crash_emit"/>
      <label kind="guard" x="52" y="-52">g &gt;= crashStart</label>
      <label kind="assignment" x="48" y="-24">rep = 0, gap = 0</label>
    </transition>
    <transition>
      <source ref="crash_emit"/>
      <target ref="crash_repeat_wait"/>
      <label kind="guard" x="284" y="-82">g &lt; crashStart + crashDuration</label>
      <label kind="synchronisation" x="286" y="-54">vo_demand!</label>
      <label kind="assignment" x="280" y="-26">rep = rep + 1, gap = 0</label>
    </transition>
    <transition>
      <source ref="crash_emit"/>
      <target ref="crash_done"/>
      <label kind="guard" x="286" y="78">g &gt;= crashStart + crashDuration</label>
      <label kind="assignment" x="290" y="106">burstDone = true</label>
    </transition>
    <transition>
      <source ref="crash_repeat_wait"/>
      <target ref="crash_emit"/>
      <label kind="guard" x="356" y="-82">rep &lt; repeatCount &amp;&amp; gap &gt;= repeatGapMin</label>
    </transition>
    <transition>
      <source ref="crash_repeat_wait"/>
      <target ref="crash_between"/>
      <label kind="guard" x="254" y="54">rep == repeatCount &amp;&amp; gap &gt;= repeatGapMin</label>
      <label kind="assignment" x="250" y="82">waitBurst = 0, rep = 0</label>
    </transition>
    <transition>
      <source ref="crash_between"/>
      <target ref="crash_emit"/>
      <label kind="guard" x="246" y="122">waitBurst &gt;= sendInterval &amp;&amp; g &lt; crashStart + crashDuration</label>
      <label kind="assignment" x="240" y="150">gap = 0</label>
    </transition>
    <transition>
      <source ref="crash_between"/>
      <target ref="crash_done"/>
      <label kind="guard" x="296" y="206">g &gt;= crashStart + crashDuration</label>
      <label kind="assignment" x="296" y="234">burstDone = true</label>
    </transition>
  </template>

  <template>
    <name x="5" y="5">Controller</name>
    <declaration>clock cycle;
clock block;
clock send;</declaration>
    <location id="ctrl_listening" x="0" y="0">
      <name x="-36" y="-34">LISTENING</name>
    </location>
    <location id="ctrl_blocking" x="250" y="0">
      <name x="214" y="-34">BLOCKING</name>
      <label kind="invariant" x="172" y="20">maxContinuousBlock == 0 || cycle &lt;= maxContinuousBlock</label>
    </location>
    <location id="ctrl_sending" x="500" y="0">
      <name x="470" y="-34">SENDING</name>
      <label kind="invariant" x="372" y="20">(maxContinuousBlock == 0 || cycle &lt;= maxContinuousBlock) &amp;&amp; (sendingGuardTimeout == 0 || send &lt;= sendingGuardTimeout)</label>
    </location>
    <init ref="ctrl_listening"/>

    <transition>
      <source ref="ctrl_listening"/>
      <target ref="ctrl_listening"/>
      <label kind="synchronisation" x="42" y="-132">be_request?</label>
      <label kind="guard" x="32" y="-160">medium_free &amp;&amp; voQueueDepth &lt; voQueueThreshold</label>
      <label kind="synchronisation" x="44" y="-104">grant_be!</label>
      <label kind="assignment" x="44" y="-76">beGrantCount = beGrantCount + 1</label>
    </transition>

    <transition>
      <source ref="ctrl_listening"/>
      <target ref="ctrl_blocking"/>
      <label kind="synchronisation" x="74" y="-52">vo_demand?</label>
      <label kind="assignment" x="64" y="-24">voQueueDepth = voQueueDepth + 1, cycle = 0, block = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_blocking"/>
      <target ref="ctrl_blocking"/>
      <label kind="synchronisation" x="286" y="-52">vo_demand?</label>
      <label kind="assignment" x="276" y="-24">voQueueDepth = voQueueDepth + 1, block = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_sending"/>
      <target ref="ctrl_sending"/>
      <label kind="synchronisation" x="538" y="-52">vo_demand?</label>
      <label kind="assignment" x="530" y="-24">voQueueDepth = voQueueDepth + 1</label>
    </transition>

    <transition>
      <source ref="ctrl_listening"/>
      <target ref="ctrl_sending"/>
      <label kind="guard" x="144" y="-96">medium_free &amp;&amp; voQueueDepth &gt;= voQueueThreshold</label>
      <label kind="synchronisation" x="178" y="-122">grant_vo!</label>
      <label kind="assignment" x="176" y="-150">voGrantCount = voGrantCount + 1, send = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_blocking"/>
      <target ref="ctrl_sending"/>
      <label kind="guard" x="354" y="-96">medium_free &amp;&amp; voQueueDepth &gt;= voQueueThreshold</label>
      <label kind="synchronisation" x="380" y="-122">grant_vo!</label>
      <label kind="assignment" x="376" y="-150">voGrantCount = voGrantCount + 1, send = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_blocking"/>
      <target ref="ctrl_listening"/>
      <label kind="guard" x="104" y="104">voQueueDepth == 0 &amp;&amp; block &gt;= blockDuration</label>
    </transition>

    <transition>
      <source ref="ctrl_blocking"/>
      <target ref="ctrl_listening"/>
      <label kind="guard" x="250" y="132">maxContinuousBlock &gt; 0 &amp;&amp; cycle &gt;= maxContinuousBlock</label>
    </transition>

    <transition>
      <source ref="ctrl_sending"/>
      <target ref="ctrl_blocking"/>
      <label kind="synchronisation" x="564" y="-112">vo_tx_done_pending?</label>
      <label kind="assignment" x="546" y="-84">voQueueDepth = dec1(voQueueDepth), block = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_sending"/>
      <target ref="ctrl_listening"/>
      <label kind="synchronisation" x="540" y="110">vo_tx_done_clear?</label>
      <label kind="assignment" x="540" y="138">voQueueDepth = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_sending"/>
      <target ref="ctrl_blocking"/>
      <label kind="guard" x="402" y="84">sendingGuardTimeout &gt; 0 &amp;&amp; send &gt;= sendingGuardTimeout &amp;&amp; voQueueDepth &gt; 0</label>
      <label kind="assignment" x="428" y="112">block = 0</label>
    </transition>

    <transition>
      <source ref="ctrl_sending"/>
      <target ref="ctrl_listening"/>
      <label kind="guard" x="340" y="156">sendingGuardTimeout &gt; 0 &amp;&amp; send &gt;= sendingGuardTimeout &amp;&amp; voQueueDepth == 0</label>
    </transition>
  </template>

  <template>
    <name x="5" y="5">VoTransmitter</name>
    <declaration>clock tx;</declaration>
    <location id="tx_idle" x="0" y="0">
      <name x="-10" y="-34">IDLE</name>
    </location>
    <location id="tx_busy" x="220" y="0">
      <name x="196" y="-34">TX</name>
      <label kind="invariant" x="174" y="20">tx &lt;= voTxDuration</label>
    </location>
    <init ref="tx_idle"/>
    <transition>
      <source ref="tx_idle"/>
      <target ref="tx_busy"/>
      <label kind="synchronisation" x="46" y="-54">grant_vo?</label>
      <label kind="assignment" x="46" y="-26">tx = 0</label>
    </transition>
    <transition>
      <source ref="tx_busy"/>
      <target ref="tx_idle"/>
      <label kind="guard" x="262" y="-54">tx &gt;= voTxDuration &amp;&amp; voQueueDepth &gt; 1</label>
      <label kind="synchronisation" x="262" y="-26">vo_tx_done_pending!</label>
    </transition>
    <transition>
      <source ref="tx_busy"/>
      <target ref="tx_idle"/>
      <label kind="guard" x="262" y="52">tx &gt;= voTxDuration &amp;&amp; voQueueDepth &lt;= 1</label>
      <label kind="synchronisation" x="262" y="80">vo_tx_done_clear!</label>
    </transition>
  </template>

  <template>
    <name x="5" y="5">GrantObserver</name>
    <location id="grant_idle" x="0" y="0">
      <name x="-12" y="-34">IDLE</name>
    </location>
    <location id="grant_be" x="220" y="-80">
      <name x="186" y="-114">BE_GRANTED</name>
      <committed/>
    </location>
    <location id="grant_vo" x="220" y="80">
      <name x="188" y="110">VO_GRANTED</name>
      <committed/>
    </location>
    <init ref="grant_idle"/>
    <transition>
      <source ref="grant_idle"/>
      <target ref="grant_be"/>
      <label kind="synchronisation" x="46" y="-110">grant_be?</label>
    </transition>
    <transition>
      <source ref="grant_be"/>
      <target ref="grant_idle"/>
    </transition>
    <transition>
      <source ref="grant_idle"/>
      <target ref="grant_vo"/>
      <label kind="synchronisation" x="42" y="110">grant_vo?</label>
    </transition>
    <transition>
      <source ref="grant_vo"/>
      <target ref="grant_idle"/>
    </transition>
  </template>

  <template>
    <name x="5" y="5">Receiver</name>
    <declaration>clock dedup;</declaration>
    <location id="rx_ready" x="0" y="0">
      <name x="-18" y="-34">READY</name>
    </location>
    <location id="rx_holding" x="220" y="0">
      <name x="192" y="-34">HOLDING</name>
    </location>
    <init ref="rx_ready"/>

    <transition>
      <source ref="rx_ready"/>
      <target ref="rx_holding"/>
      <label kind="synchronisation" x="44" y="-54">vo_tx_done_pending?</label>
      <label kind="assignment" x="36" y="-26">logicalVoRx = logicalVoRx + 1, dedup = 0</label>
    </transition>
    <transition>
      <source ref="rx_ready"/>
      <target ref="rx_holding"/>
      <label kind="synchronisation" x="44" y="56">vo_tx_done_clear?</label>
      <label kind="assignment" x="36" y="84">logicalVoRx = logicalVoRx + 1, dedup = 0</label>
    </transition>

    <transition>
      <source ref="rx_holding"/>
      <target ref="rx_holding"/>
      <label kind="guard" x="276" y="-82">dedup &lt;= voDedupWindow</label>
      <label kind="synchronisation" x="276" y="-54">vo_tx_done_pending?</label>
      <label kind="assignment" x="276" y="-26">duplicateVoRx = duplicateVoRx + 1</label>
    </transition>
    <transition>
      <source ref="rx_holding"/>
      <target ref="rx_holding"/>
      <label kind="guard" x="276" y="44">dedup &lt;= voDedupWindow</label>
      <label kind="synchronisation" x="276" y="72">vo_tx_done_clear?</label>
      <label kind="assignment" x="276" y="100">duplicateVoRx = duplicateVoRx + 1</label>
    </transition>

    <transition>
      <source ref="rx_holding"/>
      <target ref="rx_ready"/>
      <label kind="guard" x="40" y="48">dedup &gt;= voDedupWindow</label>
    </transition>
  </template>

  <system>// Instance bindings
medium = Medium();
beTraffic = BeTraffic();
workload = CrashWorkload();
controller = Controller();
voTx = VoTransmitter();
grants = GrantObserver();
receiver = Receiver();

// Composed system
system medium, beTraffic, workload, controller, voTx, grants, receiver;</system>
  <queries/>
</nta>
