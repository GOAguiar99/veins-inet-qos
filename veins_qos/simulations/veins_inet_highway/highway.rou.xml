<?xml version="1.0" encoding="UTF-8"?>
<routes>

    <!-- Driver behavior profiles based on built-in SUMO models (EIDM + LC2013). -->
    <vType id="car_relaxed"
           vClass="passenger"
           carFollowModel="EIDM"
           laneChangeModel="LC2013"
           accel="1.8" decel="3.5" emergencyDecel="7.0"
           sigma="0.5" tau="1.6"
           length="4.7" minGap="2.8"
           maxSpeed="36.11"
           speedFactor="normc(0.92,0.08,0.60,1.10)"
           lcSpeedGain="0.8" lcKeepRight="2.5"
           color="0.30,0.55,1"/>

    <vType id="car_normal"
           vClass="passenger"
           carFollowModel="EIDM"
           laneChangeModel="LC2013"
           accel="2.6" decel="4.5" emergencyDecel="8.0"
           sigma="0.35" tau="1.2"
           length="4.5" minGap="2.5"
           maxSpeed="38.89"
           speedFactor="normc(1.00,0.10,0.75,1.30)"
           lcSpeedGain="1.2" lcKeepRight="1.5"
           color="0.00,0.40,1.00"/>

    <vType id="car_assertive"
           vClass="passenger"
           carFollowModel="EIDM"
           laneChangeModel="LC2013"
           accel="3.2" decel="4.8" emergencyDecel="9.0"
           sigma="0.20" tau="0.9"
           length="4.4" minGap="1.8"
           maxSpeed="41.67"
           speedFactor="normc(1.07,0.12,0.85,1.40)"
           lcSpeedGain="2.0" lcKeepRight="0.8"
           color="0.00,0.70,0.30"/>

    <vType id="truck_heavy"
           vClass="truck"
           carFollowModel="EIDM"
           laneChangeModel="LC2013"
           accel="1.2" decel="3.0" emergencyDecel="6.0"
           sigma="0.40" tau="2.0"
           length="12.0" minGap="3.2"
           maxSpeed="25.00"
           speedFactor="normc(0.95,0.05,0.80,1.05)"
           lcSpeedGain="0.4" lcKeepRight="4.0"
           color="1.00,0.60,0.00"/>

    <route id="eastbound" edges="hw_w_e"/>
    <route id="westbound" edges="hw_e_w"/>

    <!-- Keep the first dynamic vehicle alive for the full OMNeT++ run -->
    <vehicle id="node0_highway" type="car_normal" route="eastbound"
             depart="0" departLane="free" departSpeed="desired"/>

    <!-- Poisson-like arrivals (period=exp(...)) avoid unrealistic lock-step platoons. -->
    <flow id="f_east_relaxed" type="car_relaxed" route="eastbound"
          begin="1" end="95" period="exp(8.00)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_east_normal" type="car_normal" route="eastbound"
          begin="1" end="95" period="exp(4.20)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_east_assertive" type="car_assertive" route="eastbound"
          begin="1" end="95" period="exp(18.00)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_east_truck" type="truck_heavy" route="eastbound"
          begin="1" end="95" period="exp(20.00)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_west_relaxed" type="car_relaxed" route="westbound"
          begin="1" end="95" period="exp(8.50)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_west_normal" type="car_normal" route="westbound"
          begin="1" end="95" period="exp(5.20)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_west_assertive" type="car_assertive" route="westbound"
          begin="1" end="95" period="exp(20.00)"
          departLane="free" departSpeed="desired"/>

    <flow id="f_west_truck" type="truck_heavy" route="westbound"
          begin="1" end="95" period="exp(22.00)"
          departLane="free" departSpeed="desired"/>

    <!-- Small demand bump around crash trigger time (30 s). -->
    <flow id="f_east_peak" type="car_normal" route="eastbound"
          begin="26" end="42" period="exp(5.50)"
          departLane="free" departSpeed="desired"/>

</routes>
