<?xml version="1.0" encoding="UTF-8"?>
<routes>

    <!-- Vehicle types: calm vs aggressive (variance matters for traffic dynamics) -->
    <vType id="calm"
           accel="2.0" decel="4.5" sigma="0.2"
           length="4.5" minGap="2.5" maxSpeed="14"
           color="0,1,0"/>

    <vType id="aggr"
           accel="3.0" decel="5.0" sigma="0.8"
           length="4.5" minGap="1.5" maxSpeed="16"
           color="1,0,0"/>

    <!-- Routes around the square (clockwise / counterclockwise) -->
    <route id="cw"  edges="A0toB0 B0toB1 B1toA1 A1toA0"/>
    <route id="ccw" edges="A0toA1 A1toB1 B1toB0 B0toA0"/>

    <!-- Cross routes (create interactions at junctions) -->
    <route id="a0_to_b1" edges="A0toA1 A1toB1"/>
    <route id="b1_to_a0" edges="B1toB0 B0toA0"/>

    <route id="a1_to_b0" edges="A1toA0 A0toB0"/>
    <route id="b0_to_a1" edges="B0toB1 B1toA1"/>

    <!-- Flows: continuous traffic for the whole sim window -->
    <!-- Tune end to match your sim-time-limit (e.g., 60s) -->
    <!-- period controls density: smaller = more vehicles -->

    <!-- Base circulation -->
    <flow id="f_cw_calm"  type="calm" route="cw"
          begin="0" end="10" period="1.0"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <flow id="f_ccw_calm" type="calm" route="ccw"
          begin="2" end="10" period="1.2"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <!-- Aggressive drivers (lower period = more vehicles) -->
    <flow id="f_cw_aggr"  type="aggr" route="cw"
          begin="1" end="10" period="2.0"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <flow id="f_ccw_aggr" type="aggr" route="ccw"
          begin="3" end="10" period="2.2"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <!-- Short cross-traffic bursts (increase contention + topology churn) -->
    <flow id="f_a0_b1" type="calm" route="a0_to_b1"
          begin="5" end="10" period="1.5"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <flow id="f_b1_a0" type="calm" route="b1_to_a0"
          begin="6" end="10" period="1.7"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <flow id="f_a1_b0" type="aggr" route="a1_to_b0"
          begin="7" end="10" period="3.0"
          departLane="best" departSpeed="max" arrivalPos="0"/>

    <flow id="f_b0_a1" type="aggr" route="b0_to_a1"
          begin="8" end="10" period="3.2"
          departLane="best" departSpeed="max" arrivalPos="0"/>

</routes>